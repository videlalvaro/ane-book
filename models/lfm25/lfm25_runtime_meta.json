{
  "model": "LiquidAI/LFM2.5-8B-A1B",
  "model_type": "lfm2_moe",
  "hidden_size": 2048,
  "num_hidden_layers": 24,
  "layer_types": [
    "conv", "conv", "full_attention",
    "conv", "conv", "conv", "full_attention",
    "conv", "conv", "conv", "full_attention",
    "conv", "conv", "conv", "full_attention",
    "conv", "conv", "conv", "full_attention",
    "conv", "conv", "full_attention",
    "conv", "conv"
  ],
  "num_dense_layers": 2,
  "conv_L_cache": 3,
  "num_experts": 32,
  "num_experts_per_tok": 4,
  "moe_experts_per_half": 16,
  "moe_intermediate_size": 1792,
  "intermediate_size": 7168,
  "vocab_size": 128000,
  "vocab_half": 64000,
  "num_attention_heads": 32,
  "num_key_value_heads": 8,
  "head_dim": 64,
  "rope_theta": 5000000.0,
  "norm_eps": 1e-05,
  "tie_word_embeddings": true,
  "norm_topk_prob": true,
  "use_expert_bias": true,
  "routed_scaling_factor": 1.0,
  "quant": "int8_per_tensor_linear_symmetric",
  "shard_budget_mb": 250,
  "compute_units": "ALL",
  "ane_soft_routing": false,
  "attention_layer_indices": [2, 6, 10, 14, 18, 21],
  "shard_naming": {
    "dense_layer": "lfm25_dense_layer{i}.mlmodelc",
    "conv_operator": "lfm25_op_layer{i}.mlmodelc",
    "attn_layer": "lfm25_attn_layer{i}.mlmodelc",
    "moe_half0": "lfm25_moe0_layer{i}.mlmodelc",
    "moe_half1": "lfm25_moe1_layer{i}.mlmodelc",
    "lm_head0": "lfm25_lm_head0.mlmodelc",
    "lm_head1": "lfm25_lm_head1.mlmodelc"
  },
  "shard_inputs": {
    "dense_layer": ["hidden: [1,2048,1,1]", "conv_state: [1,2048,3,1]"],
    "conv_operator": ["hidden: [1,2048,1,1]", "conv_state: [1,2048,3,1]"],
    "attn_layer": ["hidden: [1,2048,1,1]", "k_cache: [1,512,2048,1]", "v_cache: [1,512,2048,1]",
                   "write_mask: [1,1,2048,1]", "attn_mask: [1,1,1,2048]",
                   "cos: [1,64,1,1]", "sin: [1,64,1,1]"],
    "moe_half": ["ffn_normed: [1,2048,1,1]", "routing_weights: [1,16,1,1]"],
    "lm_head": ["hidden: [1,2048,1,1]"]
  },
  "shard_outputs": {
    "dense_layer": ["updated_hidden: [1,2048,1,1]", "new_conv_state: [1,2048,3,1]"],
    "conv_operator": ["updated_hidden", "new_conv_state", "ffn_normed", "routing_weights: [1,32,1,1]"],
    "attn_layer": ["updated_hidden: [1,2048,1,1]", "new_k: [1,512,2048,1]", "new_v: [1,512,2048,1]",
                   "ffn_normed: [1,2048,1,1]", "routing_weights: [1,32,1,1]"],
    "moe_half0": ["moe_contribution_half0: [1,2048,1,1]"],
    "moe_half1": ["moe_contribution_half1: [1,2048,1,1]"],
    "lm_head0": ["logits_half0: [1,64000,1,1]"],
    "lm_head1": ["logits_half1: [1,64000,1,1]"]
  },
  "host_weights_file": "lfm25_host_weights.bin",
  "host_weights_layout": {
    "offset_0": "emb_norm_weight: float32[2048] = 8192 bytes",
    "offset_8192": "expert_bias: float32[24][32] row-major = 3072 bytes"
  },
  "total_shards": 70,
  "disk_estimate_gb": 8.0,
  "conv_state_size_per_layer_kb": 24,
  "conv_state_total_kb": 432,
  "status": "quality_gate_passed",
  "quality_gate": {
    "gate": "teacher_forced",
    "cosine": 0.9957,
    "threshold": 0.97,
    "top1_token": 7085,
    "top1_match": true,
    "validator": "validators/lfm25_golden.py --compare-tf"
  },
  "notes": [
    "ShortConv: depthwise Conv1d(kernel=3) maps to Conv2d(kernel=(3,1), groups=H)",
    "ShortConv state [1,H,3,1] passed as regular tensor (not MLState — too small to need it)",
    "MoE split at 16 experts per shard: ~176 MB each (under 250 MB ANE ceiling)",
    "Top-4 routing: scores=sigmoid+expert_bias, top-4 selected, renormalised to sum=1",
    "Tied embeddings: lm_head weight loaded from embed_tokens.weight slice",
    "ANE law: any INT4 quantization would cause CPU fallback — INT8 only",
    "QK-norm: per-head RMSNorm on Q and K, head-major reshape [n_heads, dh] before apply",
    "lfm25_host_weights.bin: 11264 bytes; committed to git (safe to ship)"
  ]
}
