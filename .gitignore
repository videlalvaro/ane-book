# .gitignore for ane-models

# Model weights (large binary files — download separately)
models/**/*.gguf
models/**/*.safetensors
models/**/*.bin
models/**/model-*.safetensors
# Exception: small host-side weights committed to git (emb_norm + expert_bias, 11 KB)
!models/lfm25/ane/lfm25_host_weights.bin

# CoreML compiled artifacts (rebuilt locally)
**/*.mlmodelc/
**/*.mlpackage/

# Python envs
.venv/
.venv313/
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Xcode / CoreML temp
*.mlmodel
cml_tmp/

# Build outputs
target/
build/

# Large derived artifacts — regenerate from safetensors with --generate
models/lfm25/ane/lfm25_golden.npz
models/lfm25/ane/lfm25_hidden_states.npz
models/lfm25/ane/lfm25_single_token_golden.npz
